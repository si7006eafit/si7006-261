{
  "id": null,
  "uid": "kafka-mongo-raw",
  "title": "Kafka → MongoDB RAW Events Dashboard",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Total eventos RAW",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://dashboard-api:8000/raw_total",
          "format": "table",
          "parser": "jq",
          "root_selector": "."
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "value",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
