      "type": "stat",
      "title": "Total alertas",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://dashboard-api:8000/alerts_total",
          "format": "table",
          "parser": "jq",
	  "root_selector": "."
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "value",
          "values": false
        },
